[
  {
    "label": "Django: Run Server",
    "adapter": "Debugpy",
    "request": "launch",
    "program": "${ZED_WORKTREE_ROOT}/manage.py",
    "args": ["runserver", "0.0.0.0:8000"],
    "django": true,
    "env": {
      "DJANGO_SETTINGS_MODULE": "config.settings.dev"
    }
  },
  {
    "label": "Django: Run Tests",
    "adapter": "Debugpy",
    "request": "launch",
    "program": "${ZED_WORKTREE_ROOT}/manage.py",
    "args": ["test"],
    "django": true,
    "env": {
      "DJANGO_SETTINGS_MODULE": "config.settings.test"
    }
  },
  {
    "label": "Django: Run Specific Test",
    "adapter": "Debugpy",
    "request": "launch",
    "program": "${ZED_WORKTREE_ROOT}/manage.py",
    "args": ["test", "${INPUT:test_path}"],
    "django": true,
    "env": {
      "DJANGO_SETTINGS_MODULE": "config.settings.test"
    }
  },
  {
    "label": "Django: Management Command",
    "adapter": "Debugpy",
    "request": "launch",
    "program": "${ZED_WORKTREE_ROOT}/manage.py",
    "args": ["${INPUT:command}"],
    "django": true,
    "env": {
      "DJANGO_SETTINGS_MODULE": "config.settings.dev"
    }
  },
  {
    "label": "Python: Debug Current File",
    "adapter": "Debugpy",
    "request": "launch",
    "program": "${ZED_FILE}"
  }
]
